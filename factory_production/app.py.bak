# ---------- 安全配置 ----------
app.secret_key = os.environ.get("SECRET_KEY") or secrets.token_hex(32)
csrf = CSRFProtect(app)

# ---------- 上传配置 ----------
UPLOAD_FOLDER = 'static/uploads/orders'
ALLOWED_EXTENSIONS = {'png', 'jpg', 'jpeg', 'gif', 'webp'}
os.makedirs(UPLOAD_FOLDER, exist_ok=True)

def allowed_file(filename):
    return '.' in filename and filename.rsplit('.', 1)[1].lower() in ALLOWED_EXTENSIONS

# ---------- 日志配置 ----------
logging.basicConfig(
    filename='app.log',
    level=logging.INFO,
    format='%(asctime)s %(levelname)s: %(message)s'
)

# ---------- 登录限制（带自动清理防内存泄漏） ----------
login_attempts = {}
MAX_LOGIN_ATTEMPTS = 5
LOCKOUT_TIME = timedelta(minutes=15)
LOGIN_ATTEMPTS_MAX_SIZE = 10000

def _cleanup_old_attempts():
    """清理过期登录记录，防止内存泄漏"""
    now = datetime.now()
    expired = [
        ip for ip, (attempts, first_fail) in login_attempts.items()
        if attempts < MAX_LOGIN_ATTEMPTS or (now - first_fail) >= LOCKOUT_TIME
    ]
    for ip in expired[:1000]:
        login_attempts.pop(ip, None)

def is_login_blocked(ip):
    if ip not in login_attempts:
        return False
    attempts, first_fail_time = login_attempts[ip]
    if attempts >= MAX_LOGIN_ATTEMPTS:
        if datetime.now() - first_fail_time < LOCKOUT_TIME:
            return True
        else:
            del login_attempts[ip]
    return False

def record_failed_attempt(ip):
    if len(login_attempts) > LOGIN_ATTEMPTS_MAX_SIZE:
        _cleanup_old_attempts()
    now = datetime.now()
    if ip not in login_attempts:
        login_attempts[ip] = [1, now]
    else:
        attempts, first_fail = login_attempts[ip]
        login_attempts[ip] = [attempts + 1, first_fail]

def clear_attempts(ip):
    if ip in login_attempts:
        del login_attempts[ip]

# ---------- 输入校验 ----------
def validate_str(val, max_len=50, required=True):
    if required and not val:
        raise ValueError("字段不能为空")
    if val is None:
        return None
    val = str(val).strip()
    if len(val) > max_len:
        raise ValueError(f"长度不能超过 {max_len} 字符")
    return val

def validate_int(val, min_val=0, max_val=1000000):
    try:
        val = int(val)
    except (TypeError, ValueError):
        raise ValueError("必须是数字")
    if val < min_val or val > max_val:
        raise ValueError(f"数值必须在 {min_val} 到 {max_val} 之间")
    return val

def validate_float(val, min_val=0.0, max_val=1000000.0):
    try:
        val = float(val)
    except (TypeError, ValueError):
        raise ValueError("必须是数字")
    if val < min_val or val > max_val:
        raise ValueError(f"数值必须在 {min_val} 到 {max_val} 之间")
    return val

def validate_date(val):
    """校验日期格式 YYYY-MM-DD"""
    if not val:
        raise ValueError("日期不能为空")
    val = str(val).strip()
    try:
        datetime.strptime(val, '%Y-%m-%d')
    except ValueError:
        raise ValueError("日期格式必须为 YYYY-MM-DD")
    return val

def safe_json_load(s):
    try:
        return json.loads(s)
    except:
        return {}

# 注册为模板过滤器（修复order_detail页面500错误）
app.jinja_env.filters['safe_json_load'] = safe_json_load

# ---------- 数据库连接 ----------
def get_db():
    conn = sqlite3.connect(
        'production.db',
        timeout=10,
        check_same_thread=False
    )
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA journal_mode=WAL;")
    conn.execute("PRAGMA synchronous=NORMAL;")
    conn.execute("PRAGMA busy_timeout=5000;")
    return conn

# ---------- Flask-Login ----------
login_manager = LoginManager()
login_manager.init_app(app)
login_manager.login_view = 'login'
login_manager.login_message = '请先登录'

class User(UserMixin):
    def __init__(self, user_id, username, role, workshop):
        self.id = user_id
        self.username = username
        self.role = role
        self.workshop = workshop

@login_manager.user_loader
def load_user(user_id):
    conn = get_db()
    try:
        c = conn.cursor()
        c.execute("SELECT id, username, role, workshop FROM users WHERE id = ?", (user_id,))
        row = c.fetchone()
        if row:
            return User(row['id'], row['username'], row['role'], row['workshop'])
    finally:
        conn.close()
    return None

def role_required(*roles):
    def decorator(f):
        @wraps(f)
        @login_required
        def decorated_function(*args, **kwargs):
            if current_user.role not in roles:
                flash('无权限访问', 'danger')
                return redirect(url_for('index'))
            return f(*args, **kwargs)
        return decorated_function
    return decorator

def generate_order_no():
    # 使用 日期+时间戳+随机数 避免并发冲突
    today = date.today().strftime('%Y%m%d')
    ts = datetime.now().strftime('%H%M%S')
    rand = secrets.token_hex(2).upper()
    return f"PO{today}{ts}{rand}"

# ---------- 设备检测 ----------
def is_mobile():
    user_agent = request.headers.get('User-Agent', '').lower()
    mobile_keywords = ['mobile', 'android', 'iphone', 'ipad', 'phone', 'ios']
    return any(keyword in user_agent for keyword in mobile_keywords)

def render_mobile(template_name, **context):
    mobile_template = template_name.replace('.html', '_mobile.html')
    desktop_template = template_name
    if is_mobile():
        mobile_path = os.path.join(app.template_folder, mobile_template)
        if os.path.exists(mobile_path):
            return render_template(mobile_template, **context)
    return render_template(desktop_template, **context)

# ---------- CSRF 错误处理 ----------
@app.errorhandler(CSRFError)
def handle_csrf_error(e):
    if request.path.startswith('/api/'):
        response = jsonify({
            'success': False,
            'error': 'CSRF token missing or invalid',
            'detail': str(e)
        })
        response.status_code = 400
        return response
    return "CSRF验证失败，请刷新页面重试", 400

# ---------- 全局异常处理（不泄露敏感信息） ----------
@app.errorhandler(Exception)
def handle_exception(e):
    app.logger.error(f"未处理异常: {str(e)}", exc_info=True)
    if request.path.startswith('/api/'):
        response = jsonify({'success': False, 'error': '服务器内部错误'})
        response.status_code = 500
        return response
    return "服务器内部错误，请联系管理员", 500

