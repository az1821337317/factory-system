# ---------- 数据库初始化（完全重构，统一使用序号码段）----------
def init_db():
    conn = get_db()
    try:
        c = conn.cursor()

        # 用户表
        c.execute('''CREATE TABLE IF NOT EXISTS users (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            username TEXT UNIQUE NOT NULL,
            password TEXT NOT NULL,
            role TEXT NOT NULL,
            workshop TEXT
        )''')

        admin_pwd = os.environ.get("ADMIN_PASSWORD")
        if not admin_pwd:
            raise RuntimeError("请设置环境变量 ADMIN_PASSWORD（强密码）")
        c.execute("SELECT id FROM users WHERE username = 'admin'")
        if not c.fetchone():
            hashed = generate_password_hash(admin_pwd)
            c.execute("INSERT INTO users (username, password, role, workshop) VALUES (?, ?, ?, ?)",
                      ('admin', hashed, 'admin', None))

        demo_pwd = os.environ.get("DEMO_PASSWORD", "demo123456")
        workshop_users = [
            ('blow_worker', demo_pwd, 'blow'),
            ('pu_worker', demo_pwd, 'pu'),
            ('paint_worker', demo_pwd, 'paint'),
            ('plastic_worker', demo_pwd, 'plastic'),
            ('assembly_worker', demo_pwd, 'assembly')
        ]
        for username, pwd, workshop in workshop_users:
            c.execute("SELECT id FROM users WHERE username = ?", (username,))
            if not c.fetchone():
                hashed = generate_password_hash(pwd)
                c.execute("INSERT INTO users (username, password, role, workshop) VALUES (?, ?, 'worker', ?)",
                          (username, hashed, workshop))

        # 车间定义表
        c.execute('''CREATE TABLE IF NOT EXISTS workshops (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            code TEXT UNIQUE NOT NULL,
            name TEXT NOT NULL,
            sequence INTEGER NOT NULL
        )''')
        default_workshops = [
            ('blow', '吹气', 1),
            ('pu', 'PU', 1),
            ('paint', '喷漆', 2),
            ('plastic', '滴塑', 1),
            ('assembly', '成型', 3)
        ]
        for code, name, seq in default_workshops:
            c.execute("INSERT OR IGNORE INTO workshops (code, name, sequence) VALUES (?, ?, ?)", (code, name, seq))

        # 生产指令单主表（移除不再需要的字段）
        c.execute('''CREATE TABLE IF NOT EXISTS prod_orders (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            order_no TEXT UNIQUE NOT NULL,
            product_code TEXT NOT NULL,
            sole_model TEXT,
            upper_model TEXT,
            created_date TEXT NOT NULL,
            status TEXT DEFAULT 'pending',
            created_by INTEGER NOT NULL,
            created_at TEXT NOT NULL,
            notes TEXT,
            order_type TEXT DEFAULT 'assembly',
            sole_source TEXT,
            sole_material_id INTEGER,
            upper_source TEXT,
            upper_material_id INTEGER,
            other_materials TEXT,
            direct_sale BOOLEAN DEFAULT 0,
            images TEXT,
            FOREIGN KEY (created_by) REFERENCES users(id)
        )''')

        # 颜色明细表：统一为6个码段（序号1~6），彻底移除具体鞋码字段
        c.execute('''CREATE TABLE IF NOT EXISTS prod_order_colors (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            order_id INTEGER NOT NULL,
            color_name TEXT NOT NULL,
            size_1 INTEGER DEFAULT 0,
            size_2 INTEGER DEFAULT 0,
            size_3 INTEGER DEFAULT 0,
            size_4 INTEGER DEFAULT 0,
            size_5 INTEGER DEFAULT 0,
            size_6 INTEGER DEFAULT 0,
            completed_1 INTEGER DEFAULT 0,
            completed_2 INTEGER DEFAULT 0,
            completed_3 INTEGER DEFAULT 0,
            completed_4 INTEGER DEFAULT 0,
            completed_5 INTEGER DEFAULT 0,
            completed_6 INTEGER DEFAULT 0,
            FOREIGN KEY (order_id) REFERENCES prod_orders(id) ON DELETE CASCADE
        )''')

        # 工序任务表
        c.execute('''CREATE TABLE IF NOT EXISTS prod_tasks (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            order_id INTEGER NOT NULL,
            workshop_code TEXT NOT NULL,
            parent_task_id INTEGER,
            total_boxes INTEGER NOT NULL,
            completed_boxes INTEGER NOT NULL DEFAULT 0,
            status TEXT DEFAULT 'pending',
            confirmed_by INTEGER,
            confirmed_at TEXT,
            received_quantity INTEGER DEFAULT 0,
            received_at TEXT,
            FOREIGN KEY (order_id) REFERENCES prod_orders(id) ON DELETE CASCADE,
            FOREIGN KEY (workshop_code) REFERENCES workshops(code),
            FOREIGN KEY (parent_task_id) REFERENCES prod_tasks(id)
        )''')

        # 库存表：统一为6个码段（序号1~6）
        c.execute('''CREATE TABLE IF NOT EXISTS inventory (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            inventory_type TEXT NOT NULL,
            product_code TEXT NOT NULL,
            material_name TEXT NOT NULL,
            color TEXT NOT NULL,
            size_1 REAL DEFAULT 0,
            size_2 REAL DEFAULT 0,
            size_3 REAL DEFAULT 0,
            size_4 REAL DEFAULT 0,
            size_5 REAL DEFAULT 0,
            size_6 REAL DEFAULT 0,
            unit TEXT DEFAULT '双',
            created_at TEXT NOT NULL,
            updated_at TEXT NOT NULL,
            notes TEXT,
            UNIQUE(inventory_type, product_code, color)
        )''')

        # 出入库日志表
        c.execute('''CREATE TABLE IF NOT EXISTS inventory_logs (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            inventory_id INTEGER NOT NULL,
            action TEXT NOT NULL,
            sizes_json TEXT NOT NULL,
            operator_id INTEGER NOT NULL,
            timestamp TEXT NOT NULL,
            order_id INTEGER,
            task_id INTEGER,
            notes TEXT,
            FOREIGN KEY (inventory_id) REFERENCES inventory(id),
            FOREIGN KEY (operator_id) REFERENCES users(id),
            FOREIGN KEY (order_id) REFERENCES prod_orders(id),
            FOREIGN KEY (task_id) REFERENCES prod_tasks(id)
        )''')

        # --- 兼容旧数据库：同步 fix_db.py 添加的字段和表 ---
        # 1. prod_order_colors 表添加 completed 字段（如不存在）
        try:
            c.execute("SELECT completed_1 FROM prod_order_colors LIMIT 0")
        except sqlite3.OperationalError:
            for i in range(1, 7):
                c.execute(f"ALTER TABLE prod_order_colors ADD COLUMN completed_{i} INTEGER DEFAULT 0")

        # 2. inventory 表添加 unit, notes 字段（如不存在）
        for col_name, col_type in [('unit', "TEXT DEFAULT '双'"), ('notes', 'TEXT')]:
            try:
                c.execute(f"SELECT {col_name} FROM inventory LIMIT 0")
            except sqlite3.OperationalError:
                c.execute(f"ALTER TABLE inventory ADD COLUMN {col_name} {col_type}")

        # 3. prod_orders 表添加来源相关字段（如不存在）
        for col_name, col_type in [
            ('order_type', "TEXT DEFAULT 'assembly'"), ('sole_source', 'TEXT'),
            ('sole_material_id', 'INTEGER'), ('upper_source', 'TEXT'),
            ('upper_material_id', 'INTEGER'), ('other_materials', 'TEXT'),
            ('direct_sale', 'BOOLEAN DEFAULT 0'), ('images', 'TEXT'),
        ]:
            try:
                c.execute(f"SELECT {col_name} FROM prod_orders LIMIT 0")
            except sqlite3.OperationalError:
                c.execute(f"ALTER TABLE prod_orders ADD COLUMN {col_name} {col_type}")

        # 4. prod_tasks 表添加 parent_task_id, received 字段（如不存在）
        for col_name, col_type in [
            ('parent_task_id', 'INTEGER'), ('received_quantity', 'INTEGER DEFAULT 0'),
            ('received_at', 'TEXT'), ('confirmed_by', 'INTEGER'), ('confirmed_at', 'TEXT'),
        ]:
            try:
                c.execute(f"SELECT {col_name} FROM prod_tasks LIMIT 0")
            except sqlite3.OperationalError:
                c.execute(f"ALTER TABLE prod_tasks ADD COLUMN {col_name} {col_type}")

        # 5. 创建 inventory_locks 表（如不存在）
        c.execute('''CREATE TABLE IF NOT EXISTS inventory_locks (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            inventory_id INTEGER NOT NULL,
            locked_1 REAL DEFAULT 0,
            locked_2 REAL DEFAULT 0,
            locked_3 REAL DEFAULT 0,
            locked_4 REAL DEFAULT 0,
            locked_5 REAL DEFAULT 0,
            locked_6 REAL DEFAULT 0,
            order_id INTEGER,
            created_at TEXT NOT NULL,
            FOREIGN KEY (inventory_id) REFERENCES inventory(id)
        )''')

        # 6. inventory 表添加 stock_locked（如不存在）
        try:
            c.execute("SELECT stock_locked FROM inventory LIMIT 0")
        except sqlite3.OperationalError:
            c.execute("ALTER TABLE inventory ADD COLUMN stock_locked TEXT DEFAULT '{}' ")

        # 7. prod_orders 表添加 size_start / size_end（码段范围，如不存在）
        for col_name, col_type in [('size_start', 'INTEGER DEFAULT 37'), ('size_end', 'INTEGER DEFAULT 42')]:
            try:
                c.execute(f"SELECT {col_name} FROM prod_orders LIMIT 0")
            except sqlite3.OperationalError:
                c.execute(f"ALTER TABLE prod_orders ADD COLUMN {col_name} {col_type}")

        # 8. inventory 表添加 size_start / size_end（码段范围，如不存在）
        for col_name, col_type in [('size_start', 'INTEGER DEFAULT 37'), ('size_end', 'INTEGER DEFAULT 42')]:
            try:
                c.execute(f"SELECT {col_name} FROM inventory LIMIT 0")
            except sqlite3.OperationalError:
                c.execute(f"ALTER TABLE inventory ADD COLUMN {col_name} {col_type}")

        conn.commit()
    except Exception as e:
        conn.rollback()
        raise e
    finally:
        conn.close()

# ---------- 通用出库函数（统一使用序号码段，安全SQL） ----------
# 允许的数据库字段白名单（防止SQL注入）
_SIZE_FIELDS = [f'size_{i}' for i in range(1, 7)]

def consume_inventory(conn, inventory_type, product_code, color, quantities, order_id, task_id=None, operator_id=None):
    c = conn.cursor()
    now = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    operator = operator_id or current_user.id

    c.execute('''SELECT id FROM inventory 
                 WHERE inventory_type = ? AND product_code = ? AND color = ?''',
              (inventory_type, product_code, color))
    inv = c.fetchone()
    if not inv:
        raise ValueError(f'库存不存在：{inventory_type} {product_code} {color}')

    for idx, qty in enumerate(quantities):
        if qty <= 0:
            continue
        field = _SIZE_FIELDS[idx]  # 从白名单取字段名
        # 使用参数化查询，字段名通过白名单确保安全性
        c.execute(f'SELECT "{field}" FROM inventory WHERE id = ?', (inv['id'],))
        row = c.fetchone()
        current = row[0] or 0
        if current < qty:
            raise ValueError(f'库存不足：{product_code} 码段{idx+1} 需要{qty}，可用{current}')
        c.execute(f'UPDATE inventory SET "{field}" = "{field}" - ? WHERE id = ?', (qty, inv['id']))

    c.execute('''INSERT INTO inventory_logs 
                 (inventory_id, action, sizes_json, operator_id, timestamp, order_id, task_id, notes)
                 VALUES (?, 'consume_out', ?, ?, ?, ?, ?, ?)''',
              (inv['id'], json.dumps(quantities), operator, now, order_id, task_id, '成型领用出库'))
    return inv['id']

def _create_task(cursor, order_id, workshop_code, total_boxes, parent_task_id=None):
    app.logger.info(f"创建任务: order_id={order_id}, workshop={workshop_code}, total_boxes={total_boxes}, parent={parent_task_id}")
    cursor.execute('''INSERT INTO prod_tasks
        (order_id, workshop_code, parent_task_id, total_boxes, status)
        VALUES (?, ?, ?, ?, 'pending')''',
        (order_id, workshop_code, parent_task_id, total_boxes))
    app.logger.info(f"任务创建成功: id={cursor.lastrowid}, total_boxes={total_boxes}")
    return cursor.lastrowid

# ---------- 登录 ----------
@app.route('/login', methods=['GET', 'POST'])
def login():
    ip = request.remote_addr
    if is_login_blocked(ip):
        flash('尝试次数过多，请15分钟后再试', 'danger')
        return render_template('login.html')
    if request.method == 'POST':
        try:
            username = validate_str(request.form.get('username'), max_len=30)
            password = request.form.get('password', '')
        except ValueError as e:
            flash(str(e), 'danger')
            return render_template('login.html')
        conn = get_db()
        try:
            c = conn.cursor()
            c.execute("SELECT id, username, password, role, workshop FROM users WHERE username = ?", (username,))
            row = c.fetchone()
        finally:
            conn.close()
        if row and check_password_hash(row['password'], password):
            user = User(row['id'], row['username'], row['role'], row['workshop'])
            login_user(user, remember=False)
            clear_attempts(ip)
            if user.role == 'worker':
                return redirect(url_for('workshop_tasks'))
            else:
                return redirect(url_for('index'))
        else:
            record_failed_attempt(ip)
            flash('用户名或密码错误', 'danger')
    if is_mobile():
        return render_template('login_mobile.html')
    return render_template('login.html')

@app.route('/logout')
@login_required
def logout():
    logout_user()
    return redirect(url_for('login'))

# ---------- 首页 ----------
@app.route('/')
@login_required
def index():
    search = request.args.get('search', '').strip()
    conn = get_db()
    try:
        c = conn.cursor()
        sql = '''SELECT id, order_no, product_code, sole_model, upper_model, created_date, status, order_type
                 FROM prod_orders WHERE 1=1'''
        params = []
        if search:
            sql += ''' AND (order_no LIKE ? OR product_code LIKE ? OR sole_model LIKE ? OR upper_model LIKE ?)'''
            like = f'%{search}%'
            params.extend([like, like, like, like])
        sql += ' ORDER BY id DESC'
        c.execute(sql, params)
        orders = c.fetchall()
    finally:
        conn.close()
    return render_mobile('index.html', orders=orders, search=search)

# ---------- 删除指令单（POST + 仅管理员） ----------
@app.route('/order/<int:order_id>/delete', methods=['POST'])
@login_required
def delete_order(order_id):
    if current_user.role != 'admin':
        flash('无权限删除指令单', 'danger')
        return redirect(url_for('index'))
    conn = get_db()
    try:
        c = conn.cursor()
        c.execute("SELECT order_no FROM prod_orders WHERE id = ?", (order_id,))
        row = c.fetchone()
        if not row:
            flash('指令单不存在', 'danger')
            return redirect(url_for('index'))
        c.execute("DELETE FROM prod_orders WHERE id = ?", (order_id,))
        conn.commit()
        flash(f'指令单 {row["order_no"]} 已删除', 'success')
    except Exception as e:
        conn.rollback()
        flash('删除失败', 'danger')
    finally:
        conn.close()
    return redirect(url_for('index'))

# ---------- API：搜索库存 ----------
@app.route('/api/inventory/search')
@login_required
def api_inventory_search():
    q = request.args.get('q', '').strip()
    inventory_type = request.args.get('type', '').strip()
    color = request.args.get('color', '').strip()
    conn = get_db()
    try:
        c = conn.cursor()
        sql = '''SELECT id, inventory_type, product_code, material_name, color,
                        size_1, size_2, size_3, size_4, size_5, size_6,
                        unit, size_start, size_end
                 FROM inventory WHERE 1=1'''
        params = []
        if q:
            sql += " AND (product_code LIKE ? OR material_name LIKE ?)"
            params.extend([f'%{q}%', f'%{q}%'])
        if inventory_type:
            sql += " AND inventory_type = ?"
            params.append(inventory_type)
        if color:
            sql += " AND color LIKE ?"
            params.append(f'%{color}%')
        sql += " ORDER BY product_code LIMIT 50"
        c.execute(sql, params)
        results = c.fetchall()
        materials = []
        for row in results:
            quantities = [row['size_1'], row['size_2'], row['size_3'], row['size_4'], row['size_5'], row['size_6']]
            total_available = sum(quantities)
            unit = row['unit'] if row['unit'] else '双'
            stock = {}
            for i, qty in enumerate(quantities):
                if qty > 0:
                    stock[str(i+1)] = qty
            materials.append({
                'id': row['id'],
                'product_code': row['product_code'],
                'material_name': row['material_name'],
                'inventory_type': row['inventory_type'],
                'color': row['color'],
                'stock': stock,
                'unit': unit,
                'total': total_available,
                'size_start': row['size_start'] or 37,
                'size_end': row['size_end'] or 42
            })
        return jsonify(materials)
    finally:
        conn.close()

# ---------- 批量入库 ----------
@app.route('/api/inventory/batch_add', methods=['POST'])
@login_required
def api_inventory_batch_add():
    if current_user.role != 'admin':
        return jsonify({'success': False, 'error': '无权限'}), 403
    data = request.get_json()
    inventory_type = data.get('inventory_type')
    items = data.get('items', [])
    if inventory_type not in ('blow_sole', 'pu_sole', 'paint_sole', 'plastic_upper', 'domestic'):
        return jsonify({'success': False, 'error': '无效库存类型'})
    conn = get_db()
    try:
        c = conn.cursor()
        c.execute("BEGIN IMMEDIATE")
        now = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
        count = 0
        for item in items:
            product_code = item['product_code']
            material_name = item['material_name']
            color = item['color']
            sizes = item.get('sizes', [0]*6)
            unit = item.get('unit', '双')
            notes = item.get('notes', '')
            item_size_start = item.get('size_start', 37)
            item_size_end = item.get('size_end', 42)
            c.execute('''SELECT id FROM inventory
                         WHERE inventory_type = ? AND product_code = ? AND color = ?''',
                      (inventory_type, product_code, color))
            existing = c.fetchone()
            if existing:
                inv_id = existing['id']
                for i in range(6):
                    if sizes[i]:
                        c.execute(f"UPDATE inventory SET size_{i+1} = size_{i+1} + ?, updated_at = ? WHERE id = ?",
                                  (sizes[i], now, inv_id))
                c.execute("UPDATE inventory SET size_start = ?, size_end = ? WHERE id = ?",
                          (item_size_start, item_size_end, inv_id))
                action = 'batch_inbound_existing'
            else:
                c.execute('''INSERT INTO inventory
                            (inventory_type, product_code, material_name, color,
                             size_1, size_2, size_3, size_4, size_5, size_6,
                             unit, created_at, updated_at, notes, size_start, size_end)
                            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)''',
                          (inventory_type, product_code, material_name, color, *sizes, unit, now, now, notes, item_size_start, item_size_end))
                inv_id = c.lastrowid
                action = 'batch_inbound_new'
            c.execute('''INSERT INTO inventory_logs (inventory_id, action, sizes_json, operator_id, timestamp, notes)
                         VALUES (?, ?, ?, ?, ?, ?)''',
                      (inv_id, action, json.dumps({'sizes': sizes}), current_user.id, now, notes))
            count += 1
        conn.commit()
        return jsonify({'success': True, 'count': count})
    except Exception as e:
        conn.rollback()
        return jsonify({'success': False, 'error': str(e)}), 500
    finally:
        conn.close()

# ---------- 图片上传 API ----------
@app.route('/api/upload_order_image', methods=['POST'])
@login_required
def upload_order_image():
    if 'file' not in request.files:
        return jsonify({'success': False, 'error': '没有文件'}), 400
    file = request.files['file']
    if file.filename == '':
        return jsonify({'success': False, 'error': '空文件名'}), 400
    if not allowed_file(file.filename):
        return jsonify({'success': False, 'error': '不支持的文件类型'}), 400

    ext = file.filename.rsplit('.', 1)[1].lower()
    filename = f"{uuid.uuid4().hex}.{ext}"
    filepath = os.path.join(UPLOAD_FOLDER, filename)
    file.save(filepath)
    url = url_for('static', filename=f'uploads/orders/{filename}')
    return jsonify({'success': True, 'url': url, 'filename': filename})

